{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-text-file",
    "fs:read-all",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "notification:default"
  ]
}
